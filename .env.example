# Copier ce fichier en .env et adapter les valeurs

# Application
APP_NAME="Pronote 2.0"
DEBUG=false

# Base de données
# Option locale simple:
# DATABASE_URL=sqlite+aiosqlite:///./pronote.db
# Option PostgreSQL:
DATABASE_URL=postgresql+asyncpg://pronote:pronote@localhost:5432/pronote_db

# Sécurité JWT — à changer impérativement en production
SECRET_KEY=change-me-super-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
